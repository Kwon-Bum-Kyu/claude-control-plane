{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/KBK/claude-control-plane/schemas/envelope.schema.json",
  "title": "CCP Companion Envelope",
  "description": "Single JSON format emitted on stdout by every CCP slash command and subagent. Both gemini and codex companions self-validate before output. 6-key SSOT.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/successEnvelope" },
    { "$ref": "#/$defs/errorEnvelope" }
  ],
  "$defs": {
    "successEnvelope": {
      "type": "object",
      "required": ["summary", "tokens", "exit_code"],
      "additionalProperties": false,
      "properties": {
        "summary": {
          "type": "string",
          "maxLength": 500,
          "description": "Summary returned to the main Claude context. 500 chars or fewer (cap enforced to keep main-context absorption bounded)."
        },
        "result_path": {
          "type": ["string", "null"],
          "description": "Path (relative or absolute) to the full result file. May be null in foreground mode."
        },
        "tokens": { "$ref": "#/$defs/tokens" },
        "exit_code": {
          "type": "integer",
          "enum": [0]
        },
        "auto_routed": {
          "type": "boolean",
          "description": "true if invoked via the router agent's auto-delegation (canonical session + opt-in `plugin.json#config.auto_routing: true`). false (or absent) for explicit user slash invocation."
        },
        "details": { "$ref": "#/$defs/details" }
      }
    },
    "errorEnvelope": {
      "type": "object",
      "required": ["error", "exit_code"],
      "additionalProperties": false,
      "properties": {
        "error": {
          "type": "object",
          "required": ["code", "message", "action", "recovery"],
          "additionalProperties": false,
          "properties": {
            "code": {
              "type": "string",
              "pattern": "^CCP-[A-Z]+-[0-9]{3}$",
              "description": "Error catalogue SSOT (see CCP error code registry)."
            },
            "message": { "type": "string", "description": "Human-readable error message (English)." },
            "action": { "type": "string", "description": "Recovery instruction shown to the user (English)." },
            "recovery": {
              "type": "string",
              "enum": ["retry", "fallback_claude", "abort", "user_action_required"]
            }
          }
        },
        "exit_code": {
          "type": "integer",
          "minimum": 1
        },
        "auto_routed": {
          "type": "boolean",
          "description": "Same semantics as successEnvelope.auto_routed. Present in the error path so failed auto-delegation attempts are observable."
        },
        "details": { "$ref": "#/$defs/details" }
      }
    },
    "tokens": {
      "type": "object",
      "description": "Measurement-unit SSOT — 4 standardised fields. gemini's 7 fields and codex's 3 fields are absorbed into this shape inside each companion.",
      "required": ["input", "output"],
      "additionalProperties": false,
      "properties": {
        "input": { "type": "integer", "minimum": 0 },
        "cached": { "type": "integer", "minimum": 0 },
        "output": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      }
    },
    "details": {
      "type": "object",
      "description": "Per-model detail block. Keys vary by mode.",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["gemini", "codex", "router"]
        },
        "job_id": { "type": ["string", "null"] },
        "model": { "type": ["string", "null"] },
        "duration_ms": { "type": ["integer", "null"], "minimum": 0 }
      },
      "allOf": [
        {
          "if": { "properties": { "mode": { "const": "gemini" } } },
          "then": {
            "properties": {
              "gemini_session_id": {
                "type": ["string", "null"],
                "description": "UUIDv4 — gemini stats.session.id"
              }
            }
          }
        },
        {
          "if": { "properties": { "mode": { "const": "codex" } } },
          "then": {
            "properties": {
              "codex_thread_id": {
                "type": ["string", "null"],
                "description": "UUIDv7 — codex turn.completed.thread_id"
              }
            }
          }
        },
        {
          "if": { "properties": { "mode": { "const": "router" } } },
          "then": {
            "properties": {
              "decision": {
                "type": "string",
                "enum": ["claude", "gemini", "codex"],
                "description": "router-decide.mjs final decision (forwarded by the router agent)."
              },
              "target": {
                "type": ["string", "null"],
                "description": "Slash hint — `/gemini:rescue` or `/ccp:codex-rescue`. null if decision === 'claude'."
              },
              "axis": {
                "type": "string",
                "enum": ["A", "B", "C", "D"],
                "description": "4-axis classification origin. Same enum as router.mjs#classify return."
              },
              "reason_code": {
                "type": "string",
                "enum": [
                  "AXIS_A_SLASH",
                  "AXIS_A_OPTION",
                  "AXIS_A_FALLBACK_CLAUDE",
                  "AXIS_B_OVERSIZED",
                  "AXIS_B_MID_REVIEW",
                  "AXIS_B_TOO_SMALL",
                  "AXIS_C_KW_GEMINI",
                  "AXIS_C_KW_CODEX",
                  "AXIS_C_KW_CLAUDE",
                  "AXIS_C_MAIN_CONTEXT_BIND",
                  "AXIS_D_DEFAULT_CONSERVATIVE",
                  "OPT_OUT_NO_AUTO_ROUTE"
                ],
                "description": "Enum only, no free text — prevents main-context absorption of arbitrary strings."
              },
              "headless_confident": {
                "type": "boolean",
                "description": "true if multi-signal OR (env.CI / env.CLAUDE_CODE_NONINTERACTIVE / env.CLAUDE_CODE_ENTRYPOINT) confidently detected headless. boolean only — reason emitted to stderr separately."
              }
            }
          }
        }
      ]
    }
  }
}
